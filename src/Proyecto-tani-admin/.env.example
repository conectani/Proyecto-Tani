# Configuración de Supabase (ONG - Plan Gratuito)
# Obtener estas credenciales en tu panel de Supabase -> Settings -> API

# URL de la API del proyecto
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto-id.supabase.co

# Clave pública Anon (segura para usar en la aplicación móvil)
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
